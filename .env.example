# The Daily Redline - Environment Variables
# Copy this file to .env and fill in your API keys

# Anthropic Claude API
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# SendGrid Email API
# Get your key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx

# Email configuration
# Sender email (must be verified in SendGrid)
FROM_EMAIL=newsletter@yourdomain.com

# Recipient email(s)
TO_EMAIL=subscriber@example.com

# Dry run mode (true = don't send, just generate HTML preview)
# Set to false before running in production
DRY_RUN=true
