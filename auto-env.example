# The Daily Drive — Automotive Newsletter
# Environment Variables Template

# REQUIRED: Your Claude API key (from console.anthropic.com)
# Format: sk-ant-*
ANTHROPIC_API_KEY=your_anthropic_key_here

# REQUIRED: Your SendGrid API key (from app.sendgrid.com)
# Format: SG.*
SENDGRID_API_KEY=your_sendgrid_key_here

# REQUIRED: Email address to send FROM (must be verified in SendGrid)
FROM_EMAIL=your-newsletter@example.com

# REQUIRED: Email address to send TO
TO_EMAIL=subscriber@example.com

# OPTIONAL: Set to 'true' to run without sending email (good for testing)
# Default: false
DRY_RUN=false

# OPTIONAL: Maximum number of articles to fetch per run
# Default: 20
MAX_ARTICLES=20

# OPTIONAL: Set to 'true' to print full error stack traces
# Default: false (only shown if DRY_RUN or DEBUG set)
DEBUG=false
